# .env.example — copie para .env e preencha com seus valores
# Este arquivo pode ir para o GitHub (não contém dados reais)
# O .env com valores reais NUNCA deve ir para o GitHub

PORT=3000

# Supabase — em Settings > API no painel do Supabase
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Evolution API — URL do seu deploy no Railway
EVOLUTION_API_URL=https://evolution-api-xxxx.railway.app
EVOLUTION_API_KEY=sua-chave-aqui
EVOLUTION_INSTANCE=selfstore

# Número do WhatsApp do bot (ex: 5511999999999)
BOT_NUMERO=5511999999999

# Número do admin (receberá notificações)
ADMIN_CELULAR=5511888888888
